{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    /* Language */
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",

    /* React */
    "jsx": "react-jsx",

    /* Vite */
    "types": ["vite/client"],

    /* TypeScript */
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    /* Modern import rules */
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },

  "include": ["src"]
}